{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/actions/**",
              "components/buttons/**",
              "components/cards/**",
              "components/finance/**",
              "components/forms/**",
              "components/foundation/**",
              "components/lists/**",
              "components/navigation/**",
              "components/tags/**",
              "ui_kits/alinma-app/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Tajawal|Space Grotesk))/i]",
        "message": "Font not provided by the design system. Available: Tajawal, Space Grotesk."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|children|style|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: tone, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:new|ok|warn)$/]",
        "message": "<Badge> tone must be one of 'new' | 'ok' | 'warn'."
      },
      {
        "selector": "JSXOpeningElement[name.name='BalanceCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|amount|currency|style|key|ref|className|style|children)$/]",
        "message": "<BalanceCard> doesn't accept that prop. Declared props: label, amount, currency, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|disabled|icon|children|onClick|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, disabled, icon, children, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|ghost|soft|copper)$/]",
        "message": "<Button> variant must be one of 'primary' | 'ghost' | 'soft' | 'copper'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<Button> size must be one of 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Chip'] > JSXAttribute > JSXIdentifier[name!=/^(?:active|children|onClick|style|key|ref|className|style|children)$/]",
        "message": "<Chip> doesn't accept that prop. Declared props: active, children, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='FlowStat'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|tone|style|key|ref|className|style|children)$/]",
        "message": "<FlowStat> doesn't accept that prop. Declared props: label, value, tone, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='FlowStat'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:in|out|neutral)$/]",
        "message": "<FlowStat> tone must be one of 'in' | 'out' | 'neutral'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Icon'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|size|color|style|key|ref|className|style|children)$/]",
        "message": "<Icon> doesn't accept that prop. Declared props: name, size, color, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Icon'] > JSXAttribute[name.name='name'] > Literal[value!=/^(?:home|transfer|card|statement|beneficiary|government|history|verified|international|notification|servicesGrid|statementCheck)$/]",
        "message": "<Icon> name must be one of 'home' | 'transfer' | 'card' | 'statement' | 'beneficiary' | 'government' | 'history' | 'verified' | 'international' | 'notification' | 'servicesGrid' | 'statementCheck'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:placeholder|value|onChange|focused|style|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: placeholder, value, onChange, focused, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ListItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|label|chevron|onClick|style|key|ref|className|style|children)$/]",
        "message": "<ListItem> doesn't accept that prop. Declared props: icon, label, chevron, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ListItem'] > JSXAttribute[name.name='icon'] > Literal[value!=/^(?:home|transfer|card|statement|beneficiary|government|history|verified|international|notification|servicesGrid|statementCheck)$/]",
        "message": "<ListItem> icon must be one of 'home' | 'transfer' | 'card' | 'statement' | 'beneficiary' | 'government' | 'history' | 'verified' | 'international' | 'notification' | 'servicesGrid' | 'statementCheck'."
      },
      {
        "selector": "JSXOpeningElement[name.name='NavBarItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|label|active|onClick|key|ref|className|style|children)$/]",
        "message": "<NavBarItem> doesn't accept that prop. Declared props: icon, label, active, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='NavBarItem'] > JSXAttribute[name.name='icon'] > Literal[value!=/^(?:home|transfer|card|statement|beneficiary|government|history|verified|international|notification|servicesGrid|statementCheck)$/]",
        "message": "<NavBarItem> icon must be one of 'home' | 'transfer' | 'card' | 'statement' | 'beneficiary' | 'government' | 'history' | 'verified' | 'international' | 'notification' | 'servicesGrid' | 'statementCheck'."
      },
      {
        "selector": "JSXOpeningElement[name.name='QuickAction'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|label|onClick|key|ref|className|style|children)$/]",
        "message": "<QuickAction> doesn't accept that prop. Declared props: icon, label, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='QuickAction'] > JSXAttribute[name.name='icon'] > Literal[value!=/^(?:home|transfer|card|statement|beneficiary|government|history|verified|international|notification|servicesGrid|statementCheck)$/]",
        "message": "<QuickAction> icon must be one of 'home' | 'transfer' | 'card' | 'statement' | 'beneficiary' | 'government' | 'history' | 'verified' | 'international' | 'notification' | 'servicesGrid' | 'statementCheck'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
